<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"    
    xmlns:vm="clr-namespace:AutoNumber.ViewModels"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"    
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:AutoNumber"
    xmlns:is="clr-namespace:AutoNumber.Infrastructure">
    <mah:MathSubtractConverter x:Key="MathSubtractConverter"/>

    <Style x:Key="VisibilityToggleButtonStyle" TargetType="ToggleButton" BasedOn="{StaticResource MahApps.Styles.ToggleButton.Circle}">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Margin" Value="0,0,5,0"/>
        <Setter Property="Content">
            <Setter.Value>
                <iconPacks:PackIconMaterial Width="16" Height="16" Kind="EyeOffOutline"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Content">
                    <Setter.Value>
                        <iconPacks:PackIconMaterial Width="16" Height="16" Kind="EyeOutline"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <DataTemplate DataType="{x:Type vm:NameManager}">
        <Border Padding="10,0,10,0" BorderBrush="DarkGray" BorderThickness="1,0,0,0">
            <Grid x:Name="gg">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock
                    Text="Namensliste"
                    VerticalAlignment="Center"
                    Margin="0,6,0,0"
                    Grid.Row="0"
                    Grid.Column="0"/>

                <DataGrid
                    Margin="0,6,8,8"
                    VerticalAlignment="Stretch"
                    CanUserSortColumns="True"
                    CanUserAddRows="False"
                    AutoGenerateColumns="False"
                    Grid.Row="1"
                    Grid.Column="0"
                    BorderThickness="1"
                    ItemsSource="{Binding PersonsView}"
                    Style="{StaticResource MahApps.Styles.DataGrid}"
                    mah:DataGridHelper.SelectionUnit="FullRow"
                    mah:DataGridHelper.EnableCellEditAssist="True"
                    HeadersVisibility="Column"
                    GridLinesVisibility="All"
                    SelectionMode="Single"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    ColumnWidth="*">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nr." Binding="{Binding Label.Number}" Width="Auto" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name.Text }" Width="*" MinWidth="120"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel
                    Orientation="Horizontal"
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="0,6,0,0"
                    VerticalAlignment="Top">
                    <ToggleButton
                        ToolTip="Namensliste anzeigen/verbergen"
                        Style="{StaticResource VisibilityToggleButtonStyle}"
                        IsChecked="{Binding IsEnabled, Mode=TwoWay}">
                    </ToggleButton>

                    <Button
                        Width="32"
                        Height="32"
                        ToolTip="Formatierung"
                        Style="{StaticResource MahApps.Styles.Button.Circle}"
                        Command="{x:Static local:MainWindow.OpenFormatDialogCommand}"
                        CommandParameter="{Binding}">
                        <iconPacks:PackIconMaterial Kind="CogOutline" Width="16" Height="16"/>
                    </Button>
                </StackPanel>

            </Grid>
        </Border>
    </DataTemplate>

</ResourceDictionary>
