<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"    
    xmlns:vm="clr-namespace:AutoNumber.ViewModels"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"    
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:AutoNumber"
    xmlns:is="clr-namespace:AutoNumber.Infrastructure">
    <mah:MathSubtractConverter x:Key="MathSubtractConverter"/>

    <DataTemplate DataType="{x:Type vm:NameManager}">
        <Border Padding="10,0,10,0" BorderBrush="DarkGray" BorderThickness="1,0,0,0">
            <Grid x:Name="gg">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock
                    Text="Namensliste"
                    VerticalAlignment="Center"
                    Margin="0,6,0,0"
                    Grid.Row="0"
                    Grid.Column="0"/>

                <DataGrid
                    Margin="0,6,8,8"
                    VerticalAlignment="Stretch"
                    CanUserSortColumns="True"
                    CanUserAddRows="False"
                    AutoGenerateColumns="False"
                    Grid.Row="1"
                    Grid.Column="0"
                    BorderThickness="1"
                    ItemsSource="{Binding PersonsView}"
                    Style="{StaticResource MahApps.Styles.DataGrid}"
                    mah:DataGridHelper.SelectionUnit="FullRow"
                    mah:DataGridHelper.EnableCellEditAssist="True"
                    HeadersVisibility="Column"
                    GridLinesVisibility="All"
                    SelectionMode="Single"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    ColumnWidth="*">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nr." Binding="{Binding Label.Number}" Width="Auto" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name.Text }" Width="*" MinWidth="120"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel
                    Orientation="Horizontal"
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="0,6,0,0"
                    VerticalAlignment="Top">
                    <ToggleButton
                        Width="28"
                        Height="28"
                        ToolTip="Sichtbarkeit"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        FocusVisualStyle="{x:Null}"
                        IsChecked="{Binding IsEnabled, Mode=TwoWay}">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent" BorderBrush="Transparent" BorderThickness="0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <iconPacks:PackIconMaterial Width="16" Height="16" Kind="EyeOffOutline"/>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <iconPacks:PackIconMaterial Width="16" Height="16" Kind="EyeOutline"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>

                    <Button
                        Width="28"
                        Height="28"
                        Margin="6,0,0,0"
                        ToolTip="Formatierung"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        FocusVisualStyle="{x:Null}"
                        Command="{x:Static local:MainWindow.OpenFormatDialogCommand}"
                        CommandParameter="{Binding}">
                        <iconPacks:PackIconMaterial Kind="CogOutline" Width="16" Height="16"/>
                    </Button>
                </StackPanel>

            </Grid>
        </Border>
    </DataTemplate>

</ResourceDictionary>
