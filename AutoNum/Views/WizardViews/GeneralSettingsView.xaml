<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:vm="clr-namespace:AutoNumber.ViewModels"
    xmlns:Infrastructure="clr-namespace:AutoNumber.Infrastructure">

    <Infrastructure:SliderToScaleConverter x:Key="SliderToScaleConverter"/>

    <DataTemplate DataType="{x:Type vm:SettingsManager}">
        <Border BorderBrush="DarkGray" BorderThickness="1,0,0,0" Padding="10,8,10,8">
            <Expander Header="Allgemeine Einstellungen" IsExpanded="False">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="110"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" FontWeight="SemiBold" Text="Standardwerte für neue Bilder" Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Namensliste-Schrift (Slider)"/>
                    <Slider Grid.Row="1" Grid.Column="1" Margin="10,0,0,8" Minimum="0" Maximum="1"
                            Value="{Binding DefaultNamesFontScale, Converter={StaticResource SliderToScaleConverter}, Mode=TwoWay}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Titelschrift (Slider)"/>
                    <Slider Grid.Row="2" Grid.Column="1" Margin="10,0,0,8" Minimum="0" Maximum="1"
                            Value="{Binding DefaultTitleFontScale, Converter={StaticResource SliderToScaleConverter}, Mode=TwoWay}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Bildinformations-Schrift (Slider)"/>
                    <Slider Grid.Row="3" Grid.Column="1" Margin="10,0,0,8" Minimum="0" Maximum="1"
                            Value="{Binding DefaultImageInfoFontScale, Converter={StaticResource SliderToScaleConverter}, Mode=TwoWay}"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Bild-ID-Schrift (Slider)"/>
                    <Slider Grid.Row="4" Grid.Column="1" Margin="10,0,0,8" Minimum="0" Maximum="1"
                            Value="{Binding DefaultImageIdFontScale, Converter={StaticResource SliderToScaleConverter}, Mode=TwoWay}"/>

                    <Button Grid.Row="5" Grid.ColumnSpan="2" Margin="0,8,0,8" Padding="8,4" 
                            Command="{Binding ReadCurrentValuesCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext}"
                            Content="Aktuelle Werte vom Bildschirm übernehmen"/>

                    <TextBlock Grid.Row="6" Grid.ColumnSpan="2" FontWeight="SemiBold" Text="Erkennung und Speichern" Margin="0,4,0,8"/>

                    <TextBlock Grid.Row="7" Grid.Column="0" VerticalAlignment="Center" Text="Erkennung: Empfindlichkeit"/>
                    <Slider Grid.Row="7" Grid.Column="1" Margin="10,0,0,8" Minimum="1.05" Maximum="2"
                            Value="{Binding FaceScaleFactor, Mode=TwoWay}"/>

                    <TextBlock Grid.Row="8" Grid.Column="0" VerticalAlignment="Center" Text="Erkennung: Bestätigungen"/>
                    <Slider Grid.Row="8" Grid.Column="1" Margin="10,0,0,8" Minimum="1" Maximum="20"
                            Value="{Binding FaceMinNeighbors, Mode=TwoWay}"/>

                    <mah:ToggleSwitch Grid.Row="9" Grid.ColumnSpan="2"
                                      IsOn="{Binding AppendNumSuffixForOriginalSaves}"
                                      Content="Beim Originalspeichern '_num' vorschlagen"/>
                </Grid>
            </Expander>
        </Border>
    </DataTemplate>
</ResourceDictionary>
