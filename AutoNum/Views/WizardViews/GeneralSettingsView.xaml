<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:vm="clr-namespace:AutoNumber.ViewModels">

    <DataTemplate DataType="{x:Type vm:SettingsManager}">
        <Border BorderBrush="DarkGray" BorderThickness="1,0,0,0" Padding="10,8,10,8">
            <Expander Header="Allgemeine Einstellungen" IsExpanded="False">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="110"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" FontWeight="SemiBold" Text="Standardwerte für neue Bilder" Margin="0,0,0,8"/>

                    <mah:ToggleSwitch Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,8"
                                      IsOn="{Binding DefaultNamesEnabled}"
                                      Content="Namensliste standardmäßig aktiv"/>

                    <mah:ToggleSwitch Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,8"
                                      IsOn="{Binding DefaultTitleEnabled}"
                                      Content="Überschrift standardmäßig aktiv"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Labelgröße (Slider)"/>
                    <Slider Grid.Row="3" Grid.Column="1" Margin="10,0,0,8" Minimum="0" Maximum="100"
                            Value="{Binding DefaultLabelDiameterSlider, Mode=TwoWay}"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Namensschrift (Slider)"/>
                    <Slider Grid.Row="4" Grid.Column="1" Margin="10,0,0,8" Minimum="0" Maximum="100"
                            Value="{Binding DefaultNamesFontSlider, Mode=TwoWay}"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="Titelschrift (Slider)"/>
                    <Slider Grid.Row="5" Grid.Column="1" Margin="10,0,0,8" Minimum="0" Maximum="100"
                            Value="{Binding DefaultTitleFontSlider, Mode=TwoWay}"/>

                    <TextBlock Grid.Row="6" Grid.ColumnSpan="2" FontWeight="SemiBold" Text="Erkennung und Speichern" Margin="0,4,0,8"/>

                    <TextBlock Grid.Row="7" Grid.Column="0" VerticalAlignment="Center" Text="Erkennung: Empfindlichkeit"/>
                    <Slider Grid.Row="7" Grid.Column="1" Margin="10,0,0,8" Minimum="1.05" Maximum="2"
                            Value="{Binding FaceScaleFactor, Mode=TwoWay}"/>

                    <TextBlock Grid.Row="8" Grid.Column="0" VerticalAlignment="Center" Text="Erkennung: Bestätigungen"/>
                    <Slider Grid.Row="8" Grid.Column="1" Margin="10,0,0,8" Minimum="1" Maximum="20"
                            Value="{Binding FaceMinNeighbors, Mode=TwoWay}"/>

                    <mah:ToggleSwitch Grid.Row="9" Grid.ColumnSpan="2"
                                      IsOn="{Binding AppendNumSuffixForOriginalSaves}"
                                      Content="Beim Originalspeichern '_num' vorschlagen"/>
                </Grid>
            </Expander>
        </Border>
    </DataTemplate>
</ResourceDictionary>
