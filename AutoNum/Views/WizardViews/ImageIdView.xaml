<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:AutoNumber.ViewModels"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:is="clr-namespace:AutoNumber.Infrastructure"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:AutoNumber"
    mc:Ignorable="d">

    <DataTemplate DataType="{x:Type vm:ImageIdManager}">
        <Border BorderBrush="DarkGray" BorderThickness="1,0,0,0" Padding="10,0,10,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <TextBox
                    Grid.Column="0"
                    Height="40"
                    Margin="0,0,8,10"
                    Text="{Binding ImageId, UpdateSourceTrigger=PropertyChanged}"
                    mah:TextBoxHelper.Watermark="Bild-ID"
                    mah:TextBoxHelper.UseFloatingWatermark="True"
                    VerticalContentAlignment="Center"/>

                <StackPanel
                    Orientation="Horizontal"
                    Grid.Column="1"
                    VerticalAlignment="Top">
                    <ToggleButton
                        Width="28"
                        Height="28"
                        ToolTip="Sichtbarkeit"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        FocusVisualStyle="{x:Null}"
                        IsChecked="{Binding IsEnabled, Mode=TwoWay}">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent" BorderBrush="Transparent" BorderThickness="0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <iconPacks:PackIconMaterial Width="16" Height="16" Kind="EyeOffOutline"/>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <iconPacks:PackIconMaterial Width="16" Height="16" Kind="EyeOutline"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>

                    <Button
                        Width="28"
                        Height="28"
                        Margin="6,0,0,0"
                        ToolTip="Formatierung"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        FocusVisualStyle="{x:Null}"
                        Command="{x:Static local:MainWindow.OpenFormatDialogCommand}"
                        CommandParameter="{Binding}">
                        <iconPacks:PackIconMaterial Kind="FormatFont" Width="16" Height="16"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </DataTemplate>
</ResourceDictionary>
