<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:view="clr-namespace:AutoNumber.Views"
    xmlns:vm="clr-namespace:AutoNumber.ViewModels"
    xmlns:is="clr-namespace:AutoNumber.Infrastructure">

    <DataTemplate DataType="{x:Type vm:FileManager}">
        <Border Background="White" Padding="10,0" BorderBrush="DarkGray" BorderThickness="0,0,1,0" TextBlock.FontFamily="Calibri" TextBlock.FontSize="16">
            <StackPanel>
                <Button 
                    Content="Bild öffnen" Command="{Binding OpenImageCommand}"
                    HorizontalAlignment="Stretch" Padding="20,5" Margin="0,0,0,5"
                    Style="{StaticResource MahApps.Styles.Button.Square.Accent}" FontSize="13" mah:ControlsHelper.ContentCharacterCasing="Upper" 
                    />

                <TextBlock  TextWrapping="Wrap"  TextAlignment="Justify" FontSize="13">                                      
                    <Run Text="Unter&#x00AD;stützte Formate: JPG, PNG, TIFF, BMP and GIF."/><LineBreak/>
                </TextBlock>


                <Button 
                    Content="Ergebnis speichern" Command="{Binding SaveImageCommand}"
                    HorizontalAlignment="Stretch" Padding="20,5" Margin="0,10,0,10"
                    Style="{StaticResource MahApps.Styles.Button.Square.Accent}" FontSize="13" mah:ControlsHelper.ContentCharacterCasing="Upper" 
                    />

                <CheckBox Content="PDF erzeugen" IsChecked="{Binding ExportPdfMetadata}" Margin="0,0,0,4" FontSize="13"/>
                <CheckBox Content="CSV (Excel) Daten" IsChecked="{Binding ExportCsvMetadata}" Margin="0,0,0,4" FontSize="13"/>
                <CheckBox Content="JSON Daten" IsChecked="{Binding ExportJsonMetadata}" Margin="0,0,0,10" FontSize="13"/>

                <TextBlock  TextWrapping="Wrap"  TextAlignment="Justify" FontSize="13">                                        
                    <Run Text="Speichert eine Kopie des Originals mit der erzeugten Beschriftung."/><LineBreak/>
                    <Run Text="Optional können ein PDF Report und/oder CSV und JSON Dateien für die Weiterverbarbeitung erzeugt wer&#x00AD;den."/><LineBreak/>
                </TextBlock>

                <TextBlock TextWrapping="Wrap"  TextAlignment="Justify" FontSize="13">                                      
                    <Run FontWeight="Bold" FontSize="16" Text="Hilfe"/> <LineBreak/>
                    <Run FontWeight="SemiBold" Text="Verschieben"/> <Run Text="mit der lin&#x00AD;ken Maus&#x00AD;tas&#x00AD;te,"/> 
                    <Run FontWeight="SemiBold" Text="Zoo&#x00AD;men"/> <Run Text="mit dem Maus&#x00AD;rad."/>
                    <Run FontWeight="SemiBold" Text="Neu&#x00AD;es La&#x00AD;bel:"/> <Run Text="Rechts-&#x00AD;Klick auf ei&#x00AD;ne freie Stel&#x00AD;le."/>
                    <Run FontWeight="SemiBold" Text="Label lö&#x00AD;schen:"/> <Run Text="Rechts-&#x00AD;Klick auf ein La&#x00AD;bel"/> <LineBreak/><LineBreak/>
                    <Run FontWeight="Bold" FontSize="12" Text="Hinweis:"/><LineBreak/>
                    <Run FontSize="10 " Text="Diese Anwen&#x00AD;dung ver&#x00AD;än&#x00AD;dert oder über&#x00AD;schreibt die Original&#x00AD;datei unter keinen Um&#x00AD;stän&#x00AD;den."/>
                </TextBlock>
            </StackPanel>
        </Border>
    </DataTemplate>

</ResourceDictionary>