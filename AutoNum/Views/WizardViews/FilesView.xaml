<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:view="clr-namespace:AutoNumber.Views"
    xmlns:vm="clr-namespace:AutoNumber.ViewModels"
    xmlns:is="clr-namespace:AutoNumber.Infrastructure">

    <DataTemplate DataType="{x:Type vm:FileManager}">
        <Border Background="White" Padding="10,0" BorderBrush="DarkGray" BorderThickness="0,0,1,0" TextBlock.FontFamily="Calibri" TextBlock.FontSize="16">
            <StackPanel>
                <Button 
                    Content="Bild öffnen" Command="{Binding OpenImageCommand}"
                    HorizontalAlignment="Stretch" Padding="20,5" Margin="0,0,0,5"
                    Style="{StaticResource MahApps.Styles.Button.Square.Accent}" FontSize="13" mah:ControlsHelper.ContentCharacterCasing="Upper" 
                    />

                <TextBlock  TextWrapping="Wrap"  TextAlignment="Justify" FontSize="14">                                      
                    <Run Text="Unter&#x00AD;stützte Formate: JPG, PDF, PNG, TIFF, BMP and GIF."/><LineBreak/>
                </TextBlock>


                <Button 
                    Content="Als JPG speichern" Command="{Binding SaveJpgCommand}"
                    HorizontalAlignment="Stretch" Padding="20,5" Margin="0,10,0,5"
                    Style="{StaticResource MahApps.Styles.Button.Square.Accent}" FontSize="13" mah:ControlsHelper.ContentCharacterCasing="Upper" 
                    />

                <Button 
                    Content="Als PDF speichern" Command="{Binding SavePdfCommand}"
                    HorizontalAlignment="Stretch" Padding="20,5" Margin="0,0,0,10"
                    Style="{StaticResource MahApps.Styles.Button.Square.Accent}" FontSize="13" mah:ControlsHelper.ContentCharacterCasing="Upper" 
                    />

                <TextBlock  TextWrapping="Wrap"  TextAlignment="Justify" FontSize="14">                                        
                    <Run Text="Speichert eine Kopie des Originals mit der erzeugten Beschriftung als JPG oder PDF."/><LineBreak/>
                    <!--<Run Text="Weitere Exportoptionen finden Sie in den Einstellungen."/><LineBreak/>-->
                </TextBlock>

                <TextBlock TextWrapping="Wrap"  TextAlignment="Justify" FontSize="14">                                      
                    <Run FontWeight="Bold" Foreground="{DynamicResource MahApps.Brushes.Accent}" FontSize="16" >
                        Hilfe
                    </Run> 
                    <LineBreak/>
                    <Run FontWeight="SemiBold" Text="Verschieben"/> <Run Text="mit der lin&#x00AD;ken Maus&#x00AD;tas&#x00AD;te,"/> 
                    <Run FontWeight="SemiBold" Text="Zoo&#x00AD;men"/> <Run Text="mit dem Maus&#x00AD;rad."/>
                    <Run FontWeight="SemiBold" Text="Neu&#x00AD;es La&#x00AD;bel:"/> <Run Text="Rechts&#x00AD;Klick auf ei&#x00AD;ne freie Stel&#x00AD;le."/>
                    <Run FontWeight="SemiBold" Text="Label lö&#x00AD;schen:"/> <Run Text="Rechts-&#x00AD;Klick auf ein La&#x00AD;bel"/> <LineBreak/><LineBreak/>
                    <Run FontWeight="Bold" FontSize="16" Foreground="{DynamicResource MahApps.Brushes.Accent}">
                        Hinweis:
                    </Run>
                    <LineBreak/>
                    <Run FontSize="14 " Text="Diese Anwen&#x00AD;dung ver&#x00AD;än&#x00AD;dert oder über&#x00AD;schreibt die Original&#x00AD;datei unter keinen Um&#x00AD;stän&#x00AD;den."/>
                </TextBlock>
            </StackPanel>
        </Border>
    </DataTemplate>

</ResourceDictionary>