<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:AutoNumber.ViewModels"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:is="clr-namespace:AutoNumber.Infrastructure"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:AutoNumber"
    mc:Ignorable="d">

    <Style x:Key="VisibilityToggleButtonStyle" TargetType="ToggleButton" BasedOn="{StaticResource MahApps.Styles.ToggleButton.Circle}">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Margin" Value="0,0,5,0"/>
        <Setter Property="Content">
            <Setter.Value>
                <iconPacks:PackIconMaterial Width="16" Height="16" Kind="EyeOffOutline"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Content">
                    <Setter.Value>
                        <iconPacks:PackIconMaterial Width="16" Height="16" Kind="EyeOutline"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <DataTemplate DataType="{x:Type vm:ImageInfoManager}">
        <Border BorderBrush="DarkGray" BorderThickness="1,0,0,0" Padding="10,0,10,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <TextBox
                    Text="{Binding ImageInfo, UpdateSourceTrigger=PropertyChanged}"
                    TextWrapping="Wrap"
                    AcceptsReturn="True"
                    Grid.Column="0"
                    Height="120"
                    Margin="0,0,8,10"
                    mah:TextBoxHelper.Watermark="Beschreibung"
                    mah:TextBoxHelper.UseFloatingWatermark="True"
                    VerticalScrollBarVisibility="Auto"/>

                <StackPanel
                    Orientation="Horizontal"
                    Grid.Column="1"
                    VerticalAlignment="Top">
                    <ToggleButton
                        ToolTip="Beschreibung anzeigen/verbergen"
                        Style="{StaticResource VisibilityToggleButtonStyle}"
                        IsChecked="{Binding IsEnabled, Mode=TwoWay}">
                    </ToggleButton>

                    <Button
                        Width="32"
                        Height="32"
                        ToolTip="Formatierung"
                        Style="{StaticResource MahApps.Styles.Button.Circle}"
                        Command="{x:Static local:MainWindow.OpenFormatDialogCommand}"
                        CommandParameter="{Binding}">
                        <iconPacks:PackIconMaterial Kind="CogOutline" Width="16" Height="16"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </DataTemplate>
</ResourceDictionary>
