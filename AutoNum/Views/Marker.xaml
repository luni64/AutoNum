<UserControl   
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"    
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"    
    xmlns:vm="clr-namespace:AutoNumber.ViewModels" 
    xmlns:is="clr-namespace:AutoNumber.Infrastructure"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
    x:Class="AutoNumber.Views.Marker"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type={x:Type vm:MarkerVM}}"  
    x:Name="UC" d:DesignHeight="334" d:DesignWidth="588">

    <UserControl.Resources>
        <!--LineHeight="{Binding FontSize}"-->

        <is:DrawingFontFamilyToMediaFontFamily x:Key="DrawingFontFamilyToMediaFontFamily"/>
        <mah:MathMultiplyConverter x:Key="MathMultiplyConverter"/>
        <is:BoolToVisibilityConverter x:Key="bool2Vis"/>
        <is:DrawingColToMediaBrush x:Key="Col2Brush"/>
        <is:CenteredGlyphOffsetConverter x:Key="CenteredGlyphOffsetConverter"/>
        <is:NameTableNumberColumnWidthConverter x:Key="NameTableNumberColumnWidthConverter"/>
        <is:NameTableNameColumnWidthConverter x:Key="NameTableNameColumnWidthConverter"/>
        <is:RowPreviewFillConverter x:Key="RowPreviewFillConverter"/>

        <DataTemplate DataType="{x:Type vm:MarkerLabel}">
            <Grid 
                Visibility="{Binding Visible, Converter={StaticResource bool2Vis}}"
                ToolTip="{Binding Person.Name.Text}" ToolTipService.InitialShowDelay="25">

                <Ellipse                                    
                    HorizontalAlignment="Center"  VerticalAlignment="Center" Height="{Binding Diameter}" Width="{Binding Diameter}"
                    Stroke="{Binding EdgeColor, Converter={StaticResource Col2Brush}}"                    
                    StrokeThickness="{Binding StrokeThickness}">
                    <Ellipse.Fill>
                        <MultiBinding Converter="{StaticResource RowPreviewFillConverter}">
                            <Binding Path="Person.RowPreviewActive"/>
                            <Binding Path="Person.RowPreviewColor" Converter="{StaticResource Col2Brush}"/>
                            <Binding Path="BackgroundColor" Converter="{StaticResource Col2Brush}"/>
                        </MultiBinding>
                    </Ellipse.Fill>
                </Ellipse>

                <TextBlock x:Name="LabelNumberText"                       
                    Text="{Binding Person.Label.Number}"
                    FontSize="{Binding FontSize}" FontWeight="Normal" FontFamily="{Binding FontFamily, Converter={StaticResource DrawingFontFamilyToMediaFontFamily}, Mode=OneWay}"
                    Foreground="{Binding FontColor, Converter={StaticResource Col2Brush}}"    
                    TextAlignment="Center"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                    <TextBlock.RenderTransform>
                        <TransformGroup>
                            <TranslateTransform x:Name="myTransform">
                                <TranslateTransform.Y>
                                    <MultiBinding Converter="{StaticResource CenteredGlyphOffsetConverter}">
                                        <Binding Path="Person.Label.Number"/>
                                        <Binding ElementName="LabelNumberText" Path="FontFamily"/>
                                        <Binding ElementName="LabelNumberText" Path="FontSize"/>
                                    </MultiBinding>
                                </TranslateTransform.Y>
                            </TranslateTransform>
                        </TransformGroup>
                    </TextBlock.RenderTransform>
                </TextBlock>
            </Grid>

        </DataTemplate>

        <!--FontSize="{Binding FontSize}" FontWeight="Normal"   LineStackingStrategy="BlockLineHeight"-->
        <DataTemplate DataType="{x:Type vm:TextLabel}">
            <Grid
                Width="{Binding W}"
                Height="{Binding H}"
                Visibility="{Binding Visible, Converter={StaticResource bool2Vis}}">
                <Border BorderBrush="#AA787878" BorderThickness="1" Background="Transparent">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{Binding W, Converter={StaticResource NameTableNumberColumnWidthConverter}}"/>
                            <ColumnDefinition Width="{Binding W, Converter={StaticResource NameTableNameColumnWidthConverter}}"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" BorderBrush="#AA787878" BorderThickness="0,0,1,0" Background="Transparent">
                            <TextBlock
                                Text="{Binding Person.Label.Number}"
                                FontFamily="{Binding FontFamily, Converter={StaticResource DrawingFontFamilyToMediaFontFamily}, Mode=OneWay}"
                                Foreground="{Binding FontColor, Converter={StaticResource Col2Brush}}"
                                FontSize="{Binding FontSize}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                TextAlignment="Center"/>
                        </Border>

                        <TextBlock
                            Grid.Column="1"
                            Text="{Binding Person.Name.Text}"
                            FontFamily="{Binding FontFamily, Converter={StaticResource DrawingFontFamilyToMediaFontFamily}, Mode=OneWay}"
                            Foreground="{Binding FontColor, Converter={StaticResource Col2Brush}}"
                            FontSize="{Binding FontSize}"
                            LineStackingStrategy="BlockLineHeight"
                            LineHeight="{Binding FontSize}"
                            VerticalAlignment="Center"
                            TextAlignment="Left"
                            TextWrapping="Wrap"
                            Margin="8,0,8,0"/>
                    </Grid>
                </Border>
            </Grid>

        </DataTemplate>      

    </UserControl.Resources>

    <UserControl.Style>
        <Style TargetType="{x:Type UserControl}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Cursor" Value="SizeAll"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <Grid>
        <ContentControl x:Name="MarkerUI" Content="{Binding}"/>
    </Grid>
</UserControl>
