<mah:MetroWindow x:Class="AutoNumber.Views.TextFormatDialog"
				 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
				 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
				 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
				 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
				 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
				 xmlns:view="clr-namespace:AutoNumber.Views"
				 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
				 xmlns:is="clr-namespace:AutoNumber.Infrastructure"
				 mc:Ignorable="d"
				 Title="Formatierung"
				 Width="600"
				 Height="220"
				 ShowInTaskbar="False"
				 WindowStartupLocation="CenterOwner"
				 ResizeMode="NoResize">
	<mah:MetroWindow.Resources>
		<is:ColorConverter x:Key="ColorConverter"/>
	</mah:MetroWindow.Resources>
	<Grid Margin="16">
		<Grid.RowDefinitions>
			<RowDefinition Height="auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<view:FontManager x:Name="FontManagerControl"
						  Grid.Row="0"/>

		<Grid x:Name="NameTableOptionsPanel"
			  Grid.Row="1"
			  Margin="0,30,0,0"
			  Visibility="Collapsed">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>

			<TextBlock Grid.Column="0"
					   VerticalAlignment="Center"
					   HorizontalAlignment="Right"
					   Text="Spaltenanzahl Namensliste:"/>

			<ComboBox x:Name="NameTableColumnCountComboBox"
					  Margin="10,0,0,0"
					  Grid.Column="1"
					  Width="80"
					  HorizontalAlignment="Right"
					  SelectedValuePath="Tag">
				<ComboBoxItem Content="1" Tag="1"/>
				<ComboBoxItem Content="2" Tag="2"/>
				<ComboBoxItem Content="3" Tag="3"/>
				<ComboBoxItem Content="4" Tag="4"/>
			</ComboBox>
		</Grid>

		<StackPanel Grid.Row="2"
					Orientation="Horizontal"
					HorizontalAlignment="Right"
					VerticalAlignment="Bottom"
					Margin="0,16,0,0">
			<Button x:Name="UseAsDefaultButton"
					Content="Als Standard übernehmen"
					Width="Auto"
					Height="40"
					Margin="0,0,8,0"
					Click="UseAsDefault_Click"
					Visibility="Collapsed"/>
			<Button Content="Schließen"
					Width="110"
					Height="40"
					Click="Close_Click"/>
		</StackPanel>
	</Grid>
</mah:MetroWindow>
