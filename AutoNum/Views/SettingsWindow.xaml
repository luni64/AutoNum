<mah:MetroWindow x:Class="AutoNumber.Views.SettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 mc:Ignorable="d"
                 Title="Einstellungen"
                 Width="560"
                 Height="520"
                 ShowInTaskbar="False"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="CanResizeWithGrip">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <TabItem Header="Standards">
                <StackPanel Margin="12">
                    <mah:ToggleSwitch Margin="0,0,0,10"
                                      IsOn="{Binding DefaultNamesEnabled}"
                                      Content="Namensliste standardmäßig aktiv"/>
                    <mah:ToggleSwitch Margin="0,0,0,14"
                                      IsOn="{Binding DefaultTitleEnabled}"
                                      Content="Überschrift standardmäßig aktiv"/>

                    <TextBlock Text="Standard Labelgröße (100% = empfohlene Basis)" Margin="0,0,0,4"/>
                    <Slider Minimum="25" Maximum="200" TickFrequency="25" Value="{Binding DefaultLabelDiameterSlider, Mode=TwoWay}" Margin="0,0,0,14"/>

                    <TextBlock Text="Standard Namensschrift (100% = Label-Basis)" Margin="0,0,0,4"/>
                    <Slider Minimum="25" Maximum="200" TickFrequency="25" Value="{Binding DefaultNamesFontSlider, Mode=TwoWay}" Margin="0,0,0,14"/>

                    <TextBlock Text="Standard Titelschrift (100% = Label-Basis)" Margin="0,0,0,4"/>
                    <Slider Minimum="25" Maximum="200" TickFrequency="25" Value="{Binding DefaultTitleFontSlider, Mode=TwoWay}"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="Erkennung">
                <StackPanel Margin="12">
                    <TextBlock Text="Empfindlichkeit (ScaleFactor)" Margin="0,0,0,4"/>
                    <Slider Minimum="1.05" Maximum="2" Value="{Binding FaceScaleFactor, Mode=TwoWay}" Margin="0,0,0,14"/>

                    <TextBlock Text="Bestätigungen (MinNeighbors)" Margin="0,0,0,4"/>
                    <Slider Minimum="1" Maximum="20" Value="{Binding FaceMinNeighbors, Mode=TwoWay}"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="Speichern">
                <StackPanel Margin="12">
                    <mah:ToggleSwitch IsOn="{Binding AppendNumSuffixForOriginalSaves}"
                                      Content="Beim Speichern vom Original '_num' vorschlagen"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Schließen" Width="110" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>

    