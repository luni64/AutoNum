<mah:MetroWindow x:Class="AutoNumber.Views.SettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:Infrastructure="clr-namespace:AutoNumber.Infrastructure"
                 mc:Ignorable="d"
                 Title="Einstellungen"
                 Width="560"
                 Height="520"
                 ShowInTaskbar="False"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="CanResizeWithGrip">
    <mah:MetroWindow.Resources>
        <Infrastructure:SliderToScaleConverter x:Key="SliderToScaleConverter"/>
    </mah:MetroWindow.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" TabStripPlacement="Left" mah:HeaderedControlHelper.HeaderFontSize="16">			
            <TabItem Header="Formattierung">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="3">
                        <TextBlock Text="Standardwerte für neue Bilder" FontWeight="SemiBold" Margin="0,0,0,10"/>

                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,14" Foreground="#666666" FontSize="12">
                            AutoNumber bestimmt beim Laden eines Bildes automatisch eine Basis-Schriftgröße basierend auf der Auflösung und Größe des Bildes. Mit dem Schieberegler können Sie Faktoren relativ zu dieser Basis-Schriftgröße einstellen (100% = Basis-Schriftgröße).
                        </TextBlock>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Titel" Margin="0,0,0,4"/>
                                <Slider Minimum="0" Maximum="1" Value="{Binding DefaultTitleFontScale, Converter={StaticResource SliderToScaleConverter}, Mode=TwoWay}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" VerticalAlignment="Bottom" TextAlignment="Right" Margin="5,0,0,6" FontSize="13" FontWeight="Bold" Text="{Binding DefaultTitleFontScale, StringFormat={}{0:P0}}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Beschreibung" Margin="0,0,0,4"/>
                                <Slider Minimum="0" Maximum="1" Value="{Binding DefaultImageInfoFontScale, Converter={StaticResource SliderToScaleConverter}, Mode=TwoWay}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" VerticalAlignment="Bottom" TextAlignment="Right" Margin="5,0,0,6" FontSize="13" FontWeight="Bold" Text="{Binding DefaultImageInfoFontScale, StringFormat={}{0:P0}}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Bild-ID" Margin="0,0,0,4"/>
                                <Slider Minimum="0" Maximum="1" Value="{Binding DefaultImageIdFontScale, Converter={StaticResource SliderToScaleConverter}, Mode=TwoWay}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" VerticalAlignment="Bottom" TextAlignment="Right" Margin="5,0,0,6" FontSize="13" FontWeight="Bold" Text="{Binding DefaultImageIdFontScale, StringFormat={}{0:P0}}"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Namensliste" Margin="0,0,0,4"/>
                                <Slider Minimum="0" Maximum="1" Value="{Binding DefaultNamesFontScale, Converter={StaticResource SliderToScaleConverter}, Mode=TwoWay}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" VerticalAlignment="Bottom" TextAlignment="Right" Margin="5,0,0,6" FontSize="13" FontWeight="Bold" Text="{Binding DefaultNamesFontScale, StringFormat={}{0:P0}}"/>
                        </Grid>

                        <Button Content="Anwenden" Padding="8,4" Margin="0,8,0,0" Click="Apply_Click" ToolTip="Übernimmt die Standardwerte für das aktuelle Bild"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Sichtbarkeit">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <TextBlock Text="Standard-Sichtbarkeit für neue Bilder" FontWeight="SemiBold" Margin="0,0,0,10"/>

                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,14" Foreground="#666666" FontSize="12">
                            Lege fest, welche Elemente bei neu geladenen Bildern standardmäßig sichtbar sein sollen. Diese Einstellungen beeinflussen nur neue Bilder und können pro Bild weiterhin individuell angepasst werden.
                        </TextBlock>

                        <mah:ToggleSwitch IsOn="{Binding DefaultTitleEnabled}" Content="Titel anzeigen" Margin="0,0,0,10"/>
                        <mah:ToggleSwitch IsOn="{Binding DefaultImageInfoEnabled}" Content="Beschreibung anzeigen" Margin="0,0,0,10"/>
                        <mah:ToggleSwitch IsOn="{Binding DefaultImageIdEnabled}" Content="Bild-ID anzeigen" Margin="0,0,0,10"/>
                        <mah:ToggleSwitch IsOn="{Binding DefaultNamesEnabled}" Content="Namensliste anzeigen"/>

                        <Button Content="Anwenden" Padding="8,4" Margin="0,12,0,0" Click="ApplyVisibility_Click" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Erkennung">
                <StackPanel Margin="12">
                    <TextBlock Text="Empfindlichkeit (ScaleFactor)" Margin="0,0,0,4"/>
                    <Slider Minimum="1.05" Maximum="2" Value="{Binding FaceScaleFactor, Mode=TwoWay}" Margin="0,0,0,14"/>

                    <TextBlock Text="Bestätigungen (MinNeighbors)" Margin="0,0,0,4"/>
                    <Slider Minimum="1" Maximum="20" Value="{Binding FaceMinNeighbors, Mode=TwoWay}"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="Speichern">
                <StackPanel Margin="12">
                    <mah:ToggleSwitch IsOn="{Binding AppendNumSuffixForOriginalSaves}"
                                      Content="Beim Speichern vom Original '_num' vorschlagen"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Schließen" Width="110" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
